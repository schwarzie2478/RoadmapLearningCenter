{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=learning;Username=postgres;Password=dev"
  },
  "LLM": {
    "Provider": "openrouter",
    "MinRequestIntervalMs": 2000,
    "OpenRouter": {
      "Model": "qwen/qwen3.6-plus",
      "MaxTokens": 1500,
      "Temperature": 0.7
    },
    "OpenAI": {
      "Model": "gpt-4o"
    }
  },
  "Playground": {
    "ExecutionTimeoutSeconds": 5,
    "MemoryLimitMB": 256,
    "AllowedImports": "System,System.Linq,System.Collections.Generic,System.Text"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
