@using Microsoft.JSInterop
@inject ApiClient _api
@inject StateService _state
@inject IJSRuntime JS

<div class="code-playground">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5>Code Playground</h5>
        <button class="btn btn-sm btn-primary" @onclick="() => RunAsync()">@(_running ? "Running..." : "▶ Run Code")</button>
    </div>
    <textarea class="form-control font-monospace" style="height: 200px; font-size: 0.85rem;"
              value="@_code" @onchange="OnCodeChange"></textarea>
    @if (!string.IsNullOrEmpty(_output) || !string.IsNullOrEmpty(_errors))
    {
        <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="text-muted">Output</small>
                @if (_execTime.HasValue) { <small class="text-muted">@_execTime.Value ms</small> }
            </div>
            @if (!string.IsNullOrEmpty(_errors))
            {
                <pre class="bg-dark text-danger p-2 rounded">@_errors</pre>
            }
            @if (!string.IsNullOrEmpty(_output))
            {
                <pre class="bg-light p-2 rounded" style="max-height: 200px; overflow-y: auto;">@_output</pre>
            }
        </div>
    }
    <div class="d-flex gap-2 mt-2">
        <button class="btn btn-sm btn-outline-success" @onclick="SaveAsync" disabled="@_saving">Save</button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="CopyToClipboard">Copy</button>
    </div>
</div>

@code {
    [Parameter] public string InitialCode { get; set; } = "using System;\n\nConsole.WriteLine(\"Hello, World!\");";
    [Parameter] public Guid TopicId { get; set; }

    private string _code = "";
    private bool _running;
    private string? _output;
    private string? _errors;
    private double? _execTime;
    private bool _saving;

    protected override void OnInitialized()
    {
        _code = _state.PlaygroundCode ?? InitialCode;
    }

    private void OnCodeChange(Microsoft.AspNetCore.Components.ChangeEventArgs args)
    {
        _code = args.Value?.ToString() ?? "";
        _state.SetPlaygroundCode(_code);
    }

    private async Task RunAsync()
    {
        _running = true;
        _output = null;
        _errors = null;
        _execTime = null;
        try
        {
            var request = new PlaygroundExecuteRequest
            {
                Code = _code,
                TopicId = TopicId,
                UserId = "user1"
            };
            var response = await _api.ExecuteCodeAsync(request);
            _output = response.Output;
            _errors = response.Errors;
            _execTime = response.ExecutionTimeMs;
        }
        catch { /* API may not be running */ }
        finally { _running = false; }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            var request = new PlaygroundSaveRequest
            {
                Code = _code,
                TopicId = TopicId,
                UserId = "user1"
            };
            await _api.SaveSessionAsync(request);
        }
        finally { _saving = false; }
    }

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _code);
    }
}
