@inherits LayoutComponentBase
@inject NavigationManager Navigation

<nav class="sidebar">
    <div class="sidebar-brand">Learning</div>
    <ul class="nav flex-column">
        <li class="nav-item">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                Home
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="/roadmap">
                Roadmap
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link" href="/review">
                Review
            </NavLink>
        </li>
    </ul>
</nav>

<main class="main-content">
    <ErrorBoundary>
        <ChildContent>
            @Body
        </ChildContent>
        <ErrorContent>
            <div class="alert alert-danger mx-3 mt-3">
                <h5>Something went wrong</h5>
                <pre class="mt-2">@context.Message</pre>
                <details>
                    <summary>Full stack trace</summary>
                    <pre style="white-space:pre-wrap;font-size:0.85rem">@context.StackTrace</pre>
                </details>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</main>
