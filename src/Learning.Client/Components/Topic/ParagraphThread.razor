@using Markdig
@using Learning.Shared.Enums
@inject ApiClient _api
@inject StateService _state

<div class="paragraph-thread mt-4">
    @if (_rootParagraphs.Count == 0)
    {
        <p class="text-muted fst-italic">No questions yet. Ask one below!</p>
    }
    else
    {
        @foreach (var para in _rootParagraphs)
        {
            <div class="thread-item mb-2 p-2 border-start border-3 border-primary">
                <div class="d-flex justify-content-between mb-1">
                    <small class="text-muted text-uppercase">@para.CreatedBy</small>
                    <small class="text-muted">@para.CreatedAt.ToString("g")</small>
                </div>
                <div class="markdown-content">@((MarkupString)_rendered[para.Id])</div>
                @foreach (var reply in _repliesByParent.GetValueOrDefault(para.Id, []))
                {
                    <div class="ms-4 mt-1 thread-item p-2 border-start border-3 border-info">
                        <small class="text-muted">@reply.CreatedBy</small>
                        <small class="text-muted ms-2">@reply.CreatedAt.ToString("g")</small>
                        <div class="markdown-content">@((MarkupString)_rendered[reply.Id])</div>
                    </div>
                }
            </div>
        }
    }

    <div class="ask-box mt-3 p-3 bg-light rounded">
        <div class="mb-2">
            <select class="form-select form-select-sm" style="width: auto;"
                    @bind="_contextType">
                <option value="@ExplanationContext.Short">Short</option>
                <option value="@ExplanationContext.Deep">Deep</option>
                <option value="@ExplanationContext.Analogy">Analogy</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <input type="text" class="form-control" placeholder="Ask a question..."
                   @bind="_question" @bind:event="oninput" />
            <button class="btn btn-sm btn-primary" @onclick="AskQuestion" disabled="@_loading">
                @(_loading ? "..." : "Ask AI")
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid BlockId { get; set; }
    [Parameter] public Guid TopicId { get; set; }
    [Parameter] public List<ParagraphDto> Paragraphs { get; set; } = new();

    private List<ParagraphDto> _rootParagraphs = new();
    private Dictionary<Guid, List<ParagraphDto>> _repliesByParent = new();
    private Dictionary<Guid, string> _rendered = new();
    private string _question = "";
    private ExplanationContext _contextType = ExplanationContext.Short;
    private bool _loading;

    protected override void OnParametersSet()
    {
        // Exclude System-authored paragraphs — they duplicate the markdown rendered in the block body.
        var conversation = Paragraphs.Where(p => p.CreatedBy != ContentAuthor.System).ToList();
        _rootParagraphs = conversation.Where(p => p.Depth == 0).ToList();
        _repliesByParent = conversation
            .Where(p => p.ParentParagraphId.HasValue)
            .GroupBy(p => p.ParentParagraphId!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());

        // Pre-render markdown to HTML for every paragraph.
        _rendered = new();
        foreach (var p in conversation)
        {
            _rendered[p.Id] = string.IsNullOrWhiteSpace(p.Text)
                ? "<em class=\"text-muted\">(no text)</em>"
                : Markdown.ToHtml(p.Text);
        }
    }

    private async Task AskQuestion()
    {
        if (string.IsNullOrWhiteSpace(_question)) return;
        _loading = true;
        try
        {
            var response = await _api.AskQuestionAsync(new AIAskRequest
            {
                TopicId = TopicId, BlockId = BlockId, Question = _question,
                Context = _contextType, UserId = "user1"
            });
            
            // Render the AI response as markdown and add to thread state.
            _rendered[response.Id] = Markdown.ToHtml(response.Text);
            _rootParagraphs.Add(response);
            
            // Update full paragraph list including the new paragraph.
            Paragraphs.Add(response);
            _state.SetParagraphs(BlockId, Paragraphs);
            
            _question = "";
        }
        catch (Exception ex) { Console.WriteLine($"Ask failed: {ex.Message}"); }
        finally { _loading = false; }
    }
}
