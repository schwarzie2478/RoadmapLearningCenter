@page "/"
@page "/home"
@inject ApiClient _api
@inject StateService _state
@inject NavigationManager _nav

<PageTitle>Home — Learning</PageTitle>

<div class="container-fluid py-5">
    <section class="hero-section mb-5">
        <h1 class="display-4">Welcome to Oh My Pi Learning</h1>
        <p class="lead text-muted">An interactive way to master .NET with AI-powered explanations.</p>
        <div class="mt-3">
            <button class="btn btn-primary btn-lg me-2" @onclick="GoToRoadmap">
                Explore Roadmap
            </button>
            <button class="btn btn-outline-secondary btn-lg" @onclick="GoToReview">
                Review Topics
            </button>
        </div>
    </section>

    @if (_overview != null)
    {
        <section class="progress-section">
            <h3>Your Progress</h3>
            <div class="row">
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h2 class="text-primary">@_overview.TopicsCompleted</h2>
                            <p class="text-muted mb-0">Topics Completed</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h2 class="text-success">@_overview.TopicsExploring</h2>
                            <p class="text-muted mb-0">Currently Exploring</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h2>@_overview.OverallConfidence%</h2>
                            <p class="text-muted mb-0">Average Confidence</p>
                        </div>
                    </div>
                </div>
            </div>

            @if (_reviewList.Count > 0)
            {
                <div class="mt-4">
                    <h4 class="text-warning">Topics Needing Review</h4>
                    <ul class="list-group">
                        @foreach (var item in _reviewList)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@item.TopicTitle</span>
                                <div>
                                    <span class="badge bg-warning me-2">@item.Confidence%</span>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => RevisitTopic(item.TopicId)">
                                        Revisit
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </section>
    }
    else if (!_loading)
    {
        <p class="text-muted">Start your learning journey. Explore the roadmap to begin!</p>
    }
</div>

@code {
    private ProgressOverviewDto? _overview;
    private List<LearnerTopicStateDto> _reviewList = new();
    private bool _loading;
    private const string UserId = "user1";

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _overview = await _api.GetProgressOverviewAsync(UserId);
            _reviewList = await _api.GetReviewListAsync(UserId);
        }
        catch { /* API may not be running yet */ }
        finally { _loading = false; }
    }

    private void GoToRoadmap() => _nav.NavigateTo("/roadmap");
    private void GoToReview() => _nav.NavigateTo("/review");
    private void RevisitTopic(Guid topicId) => _nav.NavigateTo($"/topic/{topicId}");
}
